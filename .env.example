# =============================================================================
# ROOMIES — ENVIRONMENT VARIABLES EXAMPLE
#
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# Never commit .env.local — it is in .gitignore.
# This file (.env.example) is safe to commit — it has no real values.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000


# -----------------------------------------------------------------------------
# DATABASE
# PostgreSQL 16 with PostGIS installed locally.
# Run the schema: psql -U postgres -d roomies_db -f roomies_db_setup.sql
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://sumit:123sumit@127.0.0.1:5432/roomies_db


# -----------------------------------------------------------------------------
# REDIS
# Redis installed locally (no Docker).
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379


# -----------------------------------------------------------------------------
# JWT
# Use a long random string for each secret. They must be different.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=1819f3a4638b3f39990212a9f284a66f624d9e5f1eb73d4f214eced80261565de32ba70840062826833c663ee1c23996246807dda9209ec37e26a7a498b11ae8
JWT_REFRESH_SECRET=acdf6bea673999985f1e73bec19ae290e6cc6cc566e82a67baa31fe9dd4a79c4b22cd0efc97788b0236dcc1763ef0127c2a1ce856684e4e3a25834b90f3bc2d2
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d


# -----------------------------------------------------------------------------
# GOOGLE OAUTH
# From Google Cloud Console → APIs & Services → Credentials
# https://console.cloud.google.com/
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret


# -----------------------------------------------------------------------------
# EMAIL (Development)
# Ethereal Mail — fake SMTP, zero cost, no real emails sent.
# Create a free account at https://ethereal.email/
# After sending, a preview URL is logged to the console.
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=jared.raynor0@ethereal.email
SMTP_PASS=7pPc33ZkrwRT2zrGJq
SMTP_FROM=noreply@roomies.local


# -----------------------------------------------------------------------------
# FILE STORAGE
# 'local' writes files to the /uploads folder on disk.
# Switch to 'azure' when deploying — no code changes needed.
# -----------------------------------------------------------------------------
STORAGE_ADAPTER=local
